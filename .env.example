VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Gemini ───────────────────────────────────────────────────────────────
# ★ 실제 Gemini 키는 ★서버 전용★ 변수에만 둔다 (VITE_ 접두사 금지 → 번들에 안 들어감).
#   - 로컬: 아래 GEMINI_API_KEY 에 실제 키. vite dev 가 /api/gemini 프록시로 사용.
#   - 배포(Vercel): 대시보드 Environment Variables 에 GEMINI_API_KEY 등록 후 재배포.
GEMINI_API_KEY=
# (선택) 브랜드웹 전용 키. 미설정 시 GEMINI_API_KEY 사용.
GEMINI_API_KEY_BRANDWEB=

# VITE_GEMINI_API_KEY 는 더 이상 실제 키를 넣지 않는다.
# 모든 Gemini 호출은 /api/gemini 프록시로 우회되며 클라이언트의 key 파라미터는 제거된다.
# 단, 일부 코드가 "키 존재" 가드(if(!apiKey))를 하므로, 가드 통과용 더미 값만 넣는다(노출돼도 무해).
VITE_GEMINI_API_KEY=proxy
VITE_GEMINI_API_KEY_BRANDWEB=proxy

VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
